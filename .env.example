# Copy to .env and fill in. `docker compose -f docker-compose.prod.yml` reads it
# automatically. Do NOT commit the real .env (add it to .gitignore).

# --- Edge ---------------------------------------------------------------
# Public hostname for Caddy auto-HTTPS. Use ":80" for local/no-TLS testing.
DOMAIN=maps.example.com
# Browser origins allowed for CORS/WebSocket (your frontend URL).
ALLOWED_ORIGINS=https://maps.example.com

# --- Gateway free-tier gating -------------------------------------------
# Max markers a non-premium user may track per map (0 = unlimited; premium
# users always bypass). The gateway reads the `premium` claim from the JWT.
FREE_TIER_MAX_MARKERS_PER_MAP=0

# --- Shared Postgres + PostGIS (one instance, two databases) -----------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
CATALOG_DB=mapgenie               # catalog (PostGIS) — tile reads it read-only
ACCOUNTS_DB=ritchermap_accounts   # accounts (Rails) auto-creates/migrates this

# --- Secrets ------------------------------------------------------------
# HS256 secret: accounts signs session JWTs, gateway validates them. MUST match.
# Generate: openssl rand -hex 32
JWT_SECRET=replace-with-openssl-rand-hex-32
# Rails credentials key — contents of src/accounts/config/master.key. Required.
RAILS_MASTER_KEY=

# --- Google sign-in (optional) -------------------------------------------
# OAuth 2.0 *Web application* client id from the Google Cloud console
# (APIs & Services -> Credentials). The accounts service verifies Google ID
# tokens against it, and the webapp must be BUILT with the same value as
# NEXT_PUBLIC_GOOGLE_CLIENT_ID (plus your site origin listed under the
# client's "Authorized JavaScript origins"). Empty = Google sign-in disabled.
GOOGLE_CLIENT_ID=542781617041-0n0e1lov7jtsf7c7gpu3k23cv4iskg0r.apps.googleusercontent.com

# --- Catalog JVM (cheap box: cap the heap) ------------------------------
# Override the image default if you want a different cap.
# CATALOG_JAVA_OPTS=-Xmx320m -XX:MaxMetaspaceSize=128m -XX:+UseSerialGC

# --- Tile read path -----------------------------------------------------
# Where the read path fetches tiles. Points at the same object store the tiler
# writes to. The bucket must be readable over HTTP (set a public-read policy on
# MinIO, or use a Cloudflare R2 public bucket / CDN base URL here).
TILE_ORIGIN=http://minio:9000/tiles
TILE_CACHE_MB=128
# The tile service subscribes to the catalog.changed topic to invalidate its
# tile cache when a map is re-tiled. KAFKA_BROKERS is shared with the tiler and
# is wired in docker-compose.prod.yml (redpanda:9092) — no var needed here.
# Override the topic only if you renamed it on the catalog side.
CATALOG_CHANGED_TOPIC=catalog.changed

# --- Object storage for tiles (MinIO on-box by default) -----------------
# To use Cloudflare R2 instead: set S3_ENDPOINT to your R2 endpoint and the
# access keys, and drop the minio service from the compose file.
TILES_BUCKET=tiles
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=change-me-too
S3_REGION=us-east-1
CDN_BASE_URL=                      # public base URL recorded in tile manifests

# --- Kafka / Redpanda (tiler worker + catalog) --------------------------
# On-box Redpanda (docker-compose) needs no auth — leave these unset; both
# services connect PLAINTEXT to redpanda:9092. For a managed broker (Redpanda
# Cloud, MSK, Confluent) set the shared vars, plus the per-service credential
# (the Python and Java Kafka clients take auth in different shapes):
#   KAFKA_BROKERS=seed-xxxx.any.us-east-1.mpx.prd.cloud.redpanda.com:9092
#   KAFKA_SECURITY_PROTOCOL=SASL_SSL
#   KAFKA_SASL_MECHANISM=SCRAM-SHA-256   # Redpanda Cloud default; some use PLAIN
# Tiler (Python / kafka-python) — username + password:
#   KAFKA_SASL_USERNAME=
#   KAFKA_SASL_PASSWORD=
# Catalog (Java / Spring Kafka) — full JAAS login line:
#   KAFKA_SASL_JAAS_CONFIG=org.apache.kafka.common.security.scram.ScramLoginModule required username="..." password="...";
