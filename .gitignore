## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
build/
bld/
[Bb]in/
# ^ Visual Studio template junk that also swallows Rails binstubs — without this
# exception, fresh clones (CI, Koyeb) get no bin/docker-entrypoint or bin/rails
# and the accounts image can't start.
!src/accounts/bin/
[Oo]bj/
coverage.xml

# Visual Studio 2015 cache/options directory
.vs/
.vscode/
.swo
.swp

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUNIT
*.VisualState.xml
TestResult.xml

# Build Results of an ATL Project
[Dd]ebugPS/
[Rr]eleasePS/
dlldata.c

# DNX
project.lock.json
artifacts/

*_i.c
*_p.c
*_i.h
*.ilk
*.meta
*.obj
*.pch
*.pdb
*.pgc
*.pgd
*.rsp
*.sbr
*.tlb
*.tli
*.tlh
*.tmp
*.tmp_proj
*.log
*.vspscc
*.vssscc
.builds
*.pidb
*.svclog
*.scc

# Chutzpah Test files
_Chutzpah*

# Visual C++ cache files
ipch/
*.aps
*.ncb
*.opensdf
*.sdf
*.cachefile

# Visual Studio profiler
*.psess
*.vsp
*.vspx

# TFS 2012 Local Workspace
$tf/

# Guidance Automation Toolkit
*.gpState

# ReSharper is a .NET coding add-in
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# JustCode is a .NET coding add-in
.JustCode

# TeamCity is a build add-in
_TeamCity*

# DotCover is a Code Coverage Tool
*.dotCover

# NCrunch
_NCrunch_*
.*crunch*.local.xml

# MightyMoose
*.mm.*
AutoTest.Net/

# Web workbench (sass)
.sass-cache/

# Installshield output folder
[Ee]xpress/

# DocProject is a documentation generator add-in
DocProject/buildhelp/
DocProject/Help/*.HxT
DocProject/Help/*.HxC
DocProject/Help/*.hhc
DocProject/Help/*.hhk
DocProject/Help/*.hhp
DocProject/Help/Html2
DocProject/Help/html

# Click-Once directory
publish/

# Publish Web Output
*.[Pp]ublish.xml
*.azurePubxml
## TODO: Comment the next line if you want to checkin your
## web deploy settings but do note that will include unencrypted
## passwords
#*.pubxml

*.publishproj

# NuGet Packages
*.nupkg
# The packages folder can be ignored because of Package Restore
**/packages/*
# except build/, which is used as an MSBuild target.
!**/packages/build/
# Uncomment if necessary however generally it will be regenerated when needed
#!**/packages/repositories.config

# Windows Azure Build Output
csx/
*.build.csdef

# Windows Store app package directory
AppPackages/

# Visual Studio cache files
# files ending in .cache can be ignored
*.[Cc]ache
# but keep track of directories ending in .cache
!*.[Cc]ache/

# Others
ClientBin/
[Ss]tyle[Cc]op.*
~$*
*~
*.dbmdl
*.dbproj.schemaview
*.pfx
*.publishsettings
node_modules/
orleans.codegen.cs

# RIA/Silverlight projects
Generated_Code/

# Backup & report files from converting an old project file
# to a newer Visual Studio version. Backup files are not needed,
# because we have git ;-)
_UpgradeReport_Files/
Backup*/
UpgradeLog*.XML
UpgradeLog*.htm

# SQL Server files
*.mdf
*.ldf

# Business Intelligence projects
*.rdl.data
*.bim.layout
*.bim_*.settings

# Microsoft Fakes
FakesAssemblies/

# Node.js Tools for Visual Studio
.ntvs_analysis.dat

# Visual Studio 6 build log
*.plg

# Visual Studio 6 workspace options file
*.opt

# LightSwitch generated files
GeneratedArtifacts/
_Pvt_Extensions/
ModelManifest.xml
Images/
*.idea/
*.a
src/backend/web/web.admin/dashboard/package-lock.json
**/.idea

*.sonarqube
src/backend/.gradle
src/backend/web/web.admin/dashboard/.angular
src/backend/docker/.data
src/backend/docker/.env
src/backend/target
*k6

**/target/
init-scripts
_build
deps

# Ignore bundler config
.bundle

# Ignore the default SQLite database.
/db/*.sqlite3
/db/*.sqlite3-journal

# Ignore all logfiles and tempfiles.
/log/*.log
/tmp/

# Ignore Byebug command history file.
.byebug_history

# Ignore Rubymine specific files
.idea/workspace.xml
.idea/tasks.xml
.idea/usage.statistics.xml
.idea/shelf/

# Ignore local environment variables and sensitive configurations
config/application.yml
config/secrets.yml
config/database.yml # If you have local database configurations that differ from the shared template

# Ignore coverage reports from testing
/coverage/

# Ignore compiled assets
/public/assets/
/public/packs/
/public/packs-test/

# Ignore node modules if using JavaScript in conjunction with Ruby
/node_modules/

# Ignore generated documentation
/doc/


# Vendor directory
/vendor/

# Configuration files
config.php
.env

# Log files
/logs/

# Cache and temporary files
/cache/

# IDE and editor-specific files
.idea/
*.sublime-project
*.sublime-workspace

# Operating system-specific files
.DS_Store
Thumbs.db

# Build artifacts
/build/
/dist/

# Compiled artifacts
_build/
priv/static/
deps/

# Editor/OS specific files
*.swp
*.dump

# ElixirLS specific files
.elixir_ls/

# Coverage reports
cover/

# Archive artifacts (if built via "mix archive.build")
*.ez

# Protobuf codegen output (the .proto files under proto/ are the source of
# truth; per-language stubs are generated at build time via `buf generate`,
# the Gradle protobuf plugin, and prost — never committed).
proto/gen/

# Wrangler local-mode simulator state (R2 objects put without --remote land here).
.wrangler/

# Python (tiler service) — none of these were covered by the templates above.
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
tiles/
scripts/
!webapp/scripts/
.agents/